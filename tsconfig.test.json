{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true,
        "types": ["node", "vitest/globals"]
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "scripts/**/*",
        "eslint.config.ts",
        "vite.config.ts",
        "vitest.config.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
